<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gamehub - Login</title>
    <link rel="stylesheet" href="/css/general.css" />
    <link rel="stylesheet" href="/css/auth.css" />
    <link rel="stylesheet" href="/css/login.css" />
    <!-- GEWIJZIGD: test-login.js vervangen door login.js -->
    <script src="/js/login.js" defer></script>
  </head>

  <body>
    <img src="/image/game_covers.jpg" alt="" id="mainBg" />
    <header></header>

    <main>
      <section class="login-form">
        <h2>Inloggen</h2>

        <!-- GEWIJZIGD: form stuurt nu naar de echte server route -->
        <form class="login" action="/auth/login" method="post">

          <label for="email">E-mail*</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="jouw@email.com"
          />

          <label for="password">Wachtwoord*</label>
          <input type="password" id="password" name="password" required />

          <button class="auth-button" type="submit">Inloggen</button>

          <!-- GEWIJZIGD: fout- en succesmeldingen worden hier getoond via login.js -->
          <p id="login-message" class="login-message"></p>

          <p><a href="/forgot-password">Wachtwoord vergeten?</a></p>
          <p>Nog geen account? <a href="/registration">Registreer hier</a></p>
        </form>
      </section>
    </main>

    <footer></footer>
  </body>
</html>