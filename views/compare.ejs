<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gamehub - Games Vergelijken</title>
    <link rel="stylesheet" href="/css/general.css" />
    <link rel="stylesheet" href="/css/header.css" />
    <link rel="stylesheet" href="/css/footer.css" />
    <link rel="stylesheet" href="/css/compare.css" />
    <script src="/js/header.js" defer></script>
    <script src="/js/compare.js" defer></script>
  </head>
  <body>
    <header>
      <nav class="main-nav">
        <div class="nav-brand">
          <h1>🎮 Gamehub</h1>
        </div>
        <ul class="nav-menu">
          <li><a href="/" class="nav-link">🏠 Home</a></li>
          <li><a href="/games" class="nav-link">🎮 Games</a></li>
          <li><a href="/collection" class="nav-link">📚 Mijn Collectie</a></li>
          <li><a href="/guess" class="nav-link">🎯 Raad het Spel</a></li>
          <li><a href="/compare" class="nav-link active">⚖️ Vergelijk</a></li>
        </ul>
        <button class="nav-toggle">☰</button>
      </nav>
    </header>
    <main>
      <section class="compare">
        <div class="part1">
          <div class="compare_title">
            <h1>⚖️ Vergelijk Games</h1>
            <p>Kies twee games om te vergelijken</p>
          </div>
        </section>

        <section class="part2">
          <div class="name_game1">
            <form action="">
              <label for="name">Selecteer Game 1</label>
              <input
                class="gameInput1"
                type="text"
                id="gameInput1"
                name="game1"
                list="gameList"
                placeholder="🔍 Zoek een game..."
              />
            </form>
          </div>
          <div class="name_game2">
            <form action="">
              <label for="name">Selecteer Game 2</label>
              <input
                class="gameInput2"
                type="text"
                id="gameInput2"
                name="game2"
                list="gameList"
                placeholder="🔍 Zoek een game..."
              />
            </form>
          </div>
          <datalist id="gameList"></datalist>
          <div class="image_game1">
            <img
              class="image1"
              src="https://media.rawg.io/media/games/20a/20aa03a10cda45239fe22d035c0ebe64.jpg"
              alt="development"
            />
          </div>
          <div class="image_game2">
            <img
              class="image2"
              src="https://media.rawg.io/media/games/490/49016e06ae2103881ff6373248843069.jpg"
              alt="fifa"
            />
          </div>
          <div class="compare_specifications1">
            <ul>
              <li>Naam: Game 1</li>
              <li>Beoordeling: 0.0</li>
              <li>Releasedatum: 2023-01-01</li>
              <li>Speeltijd: 0 hours</li>
              <li>Metacritic: 0</li>
              <li>Platform: PC</li>
            </ul>
          </div>
          <div class="compare_specifications2">
            <ul>
              <li>Naam: Game 2</li>
              <li>Beoordeling: 0.0</li>
              <li>Releasedatum: 2023-01-01</li>
              <li>Speeltijd: 0 hours</li>
              <li>Metacritic: 0</li>
              <li>Platform: PC</li>
            </ul>
          </div>
        </section>
      </main>

    <footer>
      <p>© 2026 Gamehub — Alle rechten voorbehouden</p>
    </footer>
  </body>
</html>
