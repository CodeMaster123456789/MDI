<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/general.css" />
  <link rel="stylesheet" href="/css/header.css" />
  <link rel="stylesheet" href="/css/footer.css" />
  <link rel="stylesheet" href="/css/games.css" />
</head>
<body class="gamedetails-page">
  <%- include('partials/header') %>
  <main>
      <div class="details-card">
        <div class="details-header">
          <h2><%= game.name %></h2>
          <a href="/games" id="closeDetails">🔙</a>
        </div>

        <div class="details-content">
          <div class="details-info">
            <div class="info-item">⭐ <%= game.rating %></div>
            <div class="info-item">📅 <%= game.released %></div>
            <div class="info-item">⏱️ <%= game.playtime || 'N/A' %>h</div>
            <div class="info-item">📊 <%= game.metacritic || 'N/A' %></div>
            <div class="info-item platforms">
              <%
                const platformIcons = {
                  pc: "pc.jpg",
                  playstation: "playstation.jpg",
                  xbox: "xbox.png",
                  nintendo: "nintendo.png",
                  mac: "mac.jpg",
                };

                const platformLogos = game.parent_platforms
                  .map((p) => {
                    const slug = p.platform.slug.toLowerCase();
                    let iconHtml = "";

                    for (const key in platformIcons) {
                      if (slug.includes(key)) {
                        iconHtml = `<img src="/image/icons/${platformIcons[key]}" class="platform-icon" alt="${key}">`;
                      }
                    }
                    return iconHtml;
                  })
                  .filter(html => html !== "")
                  .join(" ");
              %>
              <%- platformLogos %>
            </div>
            <div class="info-item">
              🎭 <%= game.genres.map(g => g.name).join(", ") %>
            </div>
            <div class="collection-buttons">
              <form method="POST" action="/collection/add">
                <input type="hidden" name="gameId" value="<%= game.id %>">
                <button type="submit" class="collection-btn add-btn">➕ Voeg toe aan collectie</button>
              </form>
              <form method="POST" action="/collection/remove/<%= game.id %>">
                <button type="submit" class="collection-btn remove-btn">➖ Verwijder uit collectie</button>
              </form>
              <% if (isCurrent) { %>
                <form method="POST" action="/games/current/clear">
                  <input type="hidden" name="slug" value="<%= game.slug %>">
                  <button type="submit" class="collection-btn current-btn active">✅ Huidige game (klik om te verwijderen)</button>
                </form>
              <% } else { %>
                <form method="POST" action="/games/current/set">
                  <input type="hidden" name="slug" value="<%= game.slug %>">
                  <button type="submit" class="collection-btn current-btn">⭐ Markeer als huidige</button>
                </form>
              <% } %>
            </div>
          </div>
          <img src="<%= game.background_image %>" alt="<%= game.name %>" class="game-cover">
        </div>
      </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
